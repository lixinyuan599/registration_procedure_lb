<!--个人中心页-->
<view class="my-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <image
      class="user-avatar"
      src="{{avatarUrl || '/images/doctor-default.png'}}"
      mode="aspectFill"
    />
    <view class="user-info">
      <text class="user-name">{{nickname || '微信用户'}}</text>
      <text class="user-role" wx:if="{{role === 'doctor'}}">医生</text>
      <text class="user-role role-admin" wx:elif="{{role === 'admin'}}">管理员</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-title">常用功能</view>

    <view class="menu-item" bindtap="goMyAppointments">
      <text class="menu-icon">📋</text>
      <text class="menu-label">我的预约</text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 医生专属功能 -->
    <block wx:if="{{role === 'doctor'}}">
      <view class="menu-item" bindtap="goScheduleEdit">
        <text class="menu-icon">📅</text>
        <text class="menu-label">排班设置</text>
        <text class="menu-arrow">›</text>
      </view>
    </block>
  </view>

  <view class="menu-section">
    <view class="menu-title">其他</view>

    <view class="menu-item" bindtap="goPersonalInfo">
      <text class="menu-icon">👤</text>
      <text class="menu-label">个人信息</text>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于系统</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
