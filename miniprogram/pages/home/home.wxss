.home-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 30rpx;
}

/* 顶部横幅 */
.banner {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  padding: 60rpx 40rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 区域标题 */
.section {
  margin: 30rpx 30rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 6rpx;
}

/* 功能卡片 */
.card-row {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.15s;
}

.feature-card:active {
  transform: scale(0.98);
}

.card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bg-blue {
  background: rgba(74, 144, 217, 0.12);
}

.bg-green {
  background: rgba(82, 196, 26, 0.12);
}

.bg-orange {
  background: rgba(250, 173, 20, 0.12);
}

.card-icon {
  font-size: 44rpx;
}

.card-body {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
}

.card-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

/* 底部公告 */
.notice {
  margin: 30rpx 30rpx 0;
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.notice-label {
  font-size: 22rpx;
  color: #d48806;
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 24rpx;
  color: #666;
}
