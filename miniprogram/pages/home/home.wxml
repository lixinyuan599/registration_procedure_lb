<view class="home-page">
  <!-- 顶部横幅 -->
  <view class="banner">
    <view class="banner-content">
      <image wx:if="{{tenantLogo}}" class="banner-logo" src="{{tenantLogo}}" mode="aspectFit" />
      <view class="banner-text">
        <text class="banner-title">{{tenantName || '门诊挂号'}}</text>
        <text class="banner-subtitle" wx:if="{{tenantSubtitle}}">{{tenantSubtitle}}</text>
      </view>
    </view>
    <view class="banner-role-tag" wx:if="{{role === 'doctor'}}">
      <text>医生端</text>
    </view>
  </view>

  <!-- 预约挂号区域 -->
  <view class="section">
    <view class="section-title">预约挂号</view>
    <view class="card-row">
      <view class="feature-card card-clinic" bindtap="goClinicList">
        <view class="card-icon-wrap bg-blue">
          <text class="card-icon">🏥</text>
        </view>
        <view class="card-body">
          <text class="card-name">按门店挂号</text>
          <text class="card-desc">选择门店 → 选择医生</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
      <view class="feature-card card-doctor" bindtap="goDoctorAll">
        <view class="card-icon-wrap bg-green">
          <text class="card-icon">👨‍⚕️</text>
        </view>
        <view class="card-body">
          <text class="card-name">按医生挂号</text>
          <text class="card-desc">浏览全部医生 → 直接预约</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 医生专属功能 -->
  <view class="section" wx:if="{{role === 'doctor'}}">
    <view class="section-title">医生工作台</view>
    <view class="card-row">
      <view class="feature-card card-queue" bindtap="goDoctorQueue">
        <view class="card-icon-wrap bg-red">
          <text class="card-icon">📋</text>
        </view>
        <view class="card-body">
          <text class="card-name">挂号列表</text>
          <text class="card-desc">查看今日挂号患者 · 排队顺序</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
      <view class="feature-card card-schedule" bindtap="goScheduleEdit">
        <view class="card-icon-wrap bg-purple">
          <text class="card-icon">📅</text>
        </view>
        <view class="card-body">
          <text class="card-name">排班管理</text>
          <text class="card-desc">设置排班模板 · 调整本周/下周排班</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
      <view class="feature-card card-diagnosis-doc" bindtap="goDiagnosis">
        <view class="card-icon-wrap bg-orange">
          <text class="card-icon">🩺</text>
        </view>
        <view class="card-body">
          <text class="card-name">辅助诊断</text>
          <text class="card-desc">AI 中医辨证参考工具</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 更多功能 (患者视角) -->
  <view class="section" wx:if="{{role !== 'doctor'}}">
    <view class="section-title">更多服务</view>
    <view class="card-row">
      <view class="feature-card card-diagnosis" bindtap="goDiagnosis">
        <view class="card-icon-wrap bg-orange">
          <text class="card-icon">🩺</text>
        </view>
        <view class="card-body">
          <text class="card-name">辅助诊断</text>
          <text class="card-desc">AI 中医辨证参考</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部公告预留 -->
  <view class="notice" wx:if="{{notice}}">
    <text class="notice-label">公告</text>
    <text class="notice-text">{{notice}}</text>
  </view>
</view>
