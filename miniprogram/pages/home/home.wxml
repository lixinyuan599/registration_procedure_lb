<view class="home-page">
  <!-- 顶部横幅 -->
  <view class="banner">
    <view class="banner-text">
      <text class="banner-title">{{clinicName || '仁心堂中医门诊'}}</text>
      <text class="banner-subtitle">专注中医调理 · 用心守护健康</text>
    </view>
  </view>

  <!-- 功能区域 -->
  <view class="section">
    <view class="section-title">预约挂号</view>
    <view class="card-row">
      <view class="feature-card card-clinic" bindtap="goClinicList">
        <view class="card-icon-wrap bg-blue">
          <text class="card-icon">🏥</text>
        </view>
        <view class="card-body">
          <text class="card-name">按门店挂号</text>
          <text class="card-desc">选择门店 → 选择医生</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
      <view class="feature-card card-doctor" bindtap="goDoctorAll">
        <view class="card-icon-wrap bg-green">
          <text class="card-icon">👨‍⚕️</text>
        </view>
        <view class="card-body">
          <text class="card-name">按医生挂号</text>
          <text class="card-desc">浏览全部医生 → 直接预约</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 更多功能 -->
  <view class="section">
    <view class="section-title">更多服务</view>
    <view class="card-row">
      <view class="feature-card card-diagnosis" bindtap="goDiagnosis">
        <view class="card-icon-wrap bg-orange">
          <text class="card-icon">🩺</text>
        </view>
        <view class="card-body">
          <text class="card-name">辅助诊断</text>
          <text class="card-desc">AI 中医辨证参考</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部公告预留 -->
  <view class="notice" wx:if="{{notice}}">
    <text class="notice-label">公告</text>
    <text class="notice-text">{{notice}}</text>
  </view>
</view>
