/* 我的预约页样式 */

.page-container {
  padding-bottom: 30rpx;
}

/* 医生排班入口 */
.doctor-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #E8F1FB 0%, #D0E3F5 100%);
  border: 2rpx solid var(--primary-color);
}

.doctor-entry-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.doctor-entry-icon {
  font-size: 48rpx;
}

.doctor-entry-text {
  display: flex;
  flex-direction: column;
}

.doctor-entry-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-dark);
}

.doctor-entry-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.doctor-entry-arrow {
  font-size: 40rpx;
  color: var(--primary-color);
  font-weight: 300;
}

/* 预约卡片 */
.appointment-card {
  margin-top: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.clinic-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  margin-right: 16rpx;
}

/* 预约信息 */
.card-body {
  padding: 8rpx 0;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
}

.info-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.6;
}

.info-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.notes-text {
  color: var(--text-hint);
  font-style: italic;
}

/* 操作区域 */
.card-footer {
  padding-top: 4rpx;
}

.btn-cancel {
  background: transparent;
  color: var(--danger-color);
  border: 2rpx solid var(--danger-color);
  border-radius: 12rpx;
  font-size: 26rpx;
  padding: 14rpx 0;
  margin-top: 16rpx;
}

.btn-cancel:active {
  background: #FFF1F0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-link {
  margin-top: 24rpx;
  color: var(--primary-color);
  font-size: 28rpx;
  text-decoration: underline;
}

.loading-container {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-hint);
}
