/**
 * 全局样式 - 门诊挂号小程序
 * 设计规范: 清爽医疗蓝 + 白底卡片风格
 */

/* ===== CSS 变量 ===== */
page {
  --primary-color: #4A90D9;
  --primary-light: #E8F1FB;
  --primary-dark: #357ABD;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --danger-color: #FF4D4F;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-page: #F5F5F5;
  --bg-card: #FFFFFF;
  --border-color: #EEEEEE;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
  box-sizing: border-box;
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin: 20rpx 24rpx;
  box-shadow: var(--shadow);
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: var(--primary-color);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  width: 100%;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-primary[disabled] {
  background: #B8D4F0;
  color: rgba(255, 255, 255, 0.7);
}

.btn-outline {
  background: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 12rpx;
  padding: 18rpx 0;
  font-size: 28rpx;
  text-align: center;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.tag-blue {
  background: var(--primary-light);
  color: var(--primary-color);
}

.tag-green {
  background: #E6F7E6;
  color: var(--success-color);
}

.tag-orange {
  background: #FFF7E6;
  color: var(--warning-color);
}

.tag-red {
  background: #FFF1F0;
  color: var(--danger-color);
}

.tag-gray {
  background: #F5F5F5;
  color: var(--text-hint);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ===== 加载状态 ===== */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 16rpx 0;
}
